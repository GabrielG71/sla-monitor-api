# Auto detect text files and perform LF normalization
* text=auto

*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf
*.mjs text eol=lf
*.env* text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
mvnw text eol=lf
mvnw.cmd text eol=lf
*.properties text eol=lf
